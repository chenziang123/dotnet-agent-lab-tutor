# 复制本文件为 run.local.ps1，填入本组 MiMo 按量付费 Key 后运行。
# run.local.ps1 已在 .gitignore 中，不会提交到 Git。

$env:MIMO_API_KEY = "sk-在这里填入本组密钥"
$env:MIMO_MODEL = "mimo-v2.5-pro"
# 按量付费 sk- Key 一般无需设置 BaseUrl，程序会自动选择 api.xiaomimimo.com

Set-Location $PSScriptRoot
dotnet build
if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# 结束可能残留的旧进程
Get-Process -Name "DotNetLabTutor.Web" -ErrorAction SilentlyContinue | Stop-Process -Force

# 启动后端 API（端口 5203）
Write-Host "正在启动后端 API 服务..."
Start-Process -FilePath "cmd.exe" -ArgumentList "/c set MIMO_API_KEY=$env:MIMO_API_KEY && set MIMO_MODEL=$env:MIMO_MODEL && dotnet run --project src/DotNetLabTutor.Web --no-build" -WindowStyle Normal

Write-Host "等待后端服务启动..."
Start-Sleep -Seconds 5

# 启动 Next.js 前端（端口 3000）
Write-Host "正在启动 Next.js 前端..."
Start-Process -FilePath "cmd.exe" -ArgumentList "/c cd /d `"$PSScriptRoot\frontend`" && npm install && npm run dev" -WindowStyle Normal

Write-Host ""
Write-Host "后端 API:  http://localhost:5203" -ForegroundColor Cyan
Write-Host "Web 界面:  http://localhost:3000" -ForegroundColor Green
Write-Host "请在浏览器打开 http://localhost:3000 使用聊天界面。"
