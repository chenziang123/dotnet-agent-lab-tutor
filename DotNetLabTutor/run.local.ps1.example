# 复制本文件为 run.local.ps1，填入本组 MiMo 按量付费 Key 后运行。
# run.local.ps1 已在 .gitignore 中，不会提交到 Git。

$env:MIMO_API_KEY = "sk-在这里填入本组密钥"
$env:MIMO_MODEL = "mimo-v2.5-pro"
# 按量付费 sk- Key 一般无需设置 BaseUrl，程序会自动选择 api.xiaomimimo.com

Set-Location $PSScriptRoot
dotnet build
if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# 启动前端 Web 项目（使用 cmd /c 确保环境变量被继承）
Write-Host "正在启动前端 Web 服务..."
Start-Process -FilePath "cmd.exe" -ArgumentList "/c set MIMO_API_KEY=$env:MIMO_API_KEY && set MIMO_MODEL=$env:MIMO_MODEL && dotnet run --project src/DotNetLabTutor.Web --no-build" -WindowStyle Normal

# 等待前端启动
Write-Host "等待前端服务启动..."
Start-Sleep -Seconds 5

# 启动后端 Console 项目（可选）
Write-Host "正在启动后端 Console 服务..."
dotnet run --project src/DotNetLabTutor.Console --no-build